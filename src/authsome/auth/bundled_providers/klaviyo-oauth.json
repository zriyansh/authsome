{
  "schema_version": 1,
  "name": "klaviyo-oauth",
  "display_name": "Klaviyo (OAuth)",
  "auth_type": "oauth2",
  "flow": "pkce",
  "api_url": "a.klaviyo.com",
  "oauth": {
    "authorization_url": "https://www.klaviyo.com/oauth/authorize",
    "token_url": "https://a.klaviyo.com/oauth/token",
    "revocation_url": "https://a.klaviyo.com/oauth/revoke",
    "scopes": [
      "accounts:read"
    ],
    "pkce": true,
    "supports_device_code": false,
    "supports_dcr": false
  },
  "export": {
    "KLAVIYO_OAUTH_ACCESS_TOKEN": "ACCESS_TOKEN"
  },
  "docs_url": "https://developers.klaviyo.com/en/docs/manage_your_app"
}
